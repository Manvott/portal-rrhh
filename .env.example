# ============================================================
# PORTAL RRHH - AVA SELECCIÓN
# Variables de entorno - COPIAR A .env.local Y RELLENAR
# ============================================================

# Supabase - Obtener en: https://supabase.com/dashboard/project/xvrfjrlvhvhfkmlducir/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xvrfjrlvhvhfkmlducir.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# IMPORTANTE: Esta clave es SECRETA, nunca la expongas en el frontend
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY_AQUI

# URL del portal (sin barra final)
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nombre de la empresa (aparece en la UI y emails)
NEXT_PUBLIC_COMPANY_NAME=AVA Selección

# Email del responsable de protección de datos (RGPD)
NEXT_PUBLIC_DPO_EMAIL=privacidad@avaseleccion.es

# Email de soporte técnico
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@avaseleccion.es
